613,0.02133922,-0.00221594,0.0172685,-0.02791326,0.02145651,-0.00767706,0.02500761,-0.00365577,0.00975006,0.05979615,0.01525227,-0.04757599,0.04598468,-0.01698994,-0.01785506,0.01282327,0.03242269,-0.01012,-0.0085201,0.01582116,-0.01440989,-0.02099257,-0.03495404,0.02737981,-0.00929114,-0.01089186,0.01099861,0.01454605,0.0758193,0.00628602,0.05942437,-0.00864242,-0.01899765,-0.03660202,0.00706975,0.00843437,-0.0008153,0.01154403,0.00744081,-0.0293796,-0.08451855,-0.02385569,0.00335769,0.01895632,0.07835297,-0.00838093,-0.02618524,-0.077434,-0.02959187,0.01604383,0.03740015,0.01447399,-0.01338844,-0.05937898,-0.03200594,0.01745133,-0.01421177,0.0314569,0.06328832,0.02102236,-0.0027483,0.01080482,0.01311903,-0.06374412,0.01396075,-0.04643593,0.00064838,0.06463154,0.04302767,-0.00213994,-0.01104688,-0.03514551,-0.02429205,0.06580023,-0.02689648,-0.0338097,0.05730276,-0.03462644,-0.00400934,0.01095112,-0.06276175,-0.05274995,-0.01781061,0.04820164,0.06898951,-0.03054031,-0.00489934,-0.01552685,0.06203948,-0.02955202,0.06077481,-0.0306917,0.00254435,0.02024593,0.0578183,-0.08795053,0.00438035,-0.00505759,0.02479196,0.0710467,0.02320055,-0.00316887,-0.06380882,0.02019005,0.00543107,0.00115892,-0.07510971,-0.02768043,0.00000143,-0.01921854,0.00679398,-0.04016737,-0.00618776,0.02661042,0.01978039,0.01336161,-0.04184763,0.03996763],"last_embed":{"hash":"550f09ef43b0f192e6c0779dc8ea4766f9f365c31833267bcfd2c60cfa2341eb","tokens":5605}}},"text":null,"length":0,"last_read":{"hash":"550f09ef43b0f192e6c0779dc8ea4766f9f365c31833267bcfd2c60cfa2341eb","at":1742533448664},"key":"DDD 的实战 （第八章）.md#","lines":[1,129],"size":15324,"outlinks":[{"title":"Of course, the real challenge is to actually find an incisive model, one that captures subtle concerns of the domain experts and can drive a practical design.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":1},{"title":"Rather than making elaborate up-front design decisions, developers take code through a continuous series of small, discrete design changes, each leaving existing functionality unchanged while making the design more flexible or easier to understand.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":4},{"title":"But nearly all the literature on how to refactor focuses on mechanical changes to the code that make it easier to read or to enhance at a very detailed level.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":8},{"title":"refactoring to a deeper model.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":12},{"title":"but we shouldn’t get sidetracked trying to reduce domain modeling to a cookbook or a toolkit.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":15},{"title":"A deep model provides a lucid expression of the primary concerns of the domain experts and their most relevant knowledge while it sloughs off the superficial aspects of the domain.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":19},{"title":"slough","target":"slough","line":21},{"title":"Versatility, simplicity, and explanatory power come from a model that is truly in tune with the domain.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":24},{"title":"A well-worn glove becomes supple at the points where the fingers bend, while other parts are stiff and protective.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":31},{"title":"In addition to facilitating change, a supple design contributes to the refinement of the model itself.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":34},{"title":"To create a design really fitted to the problem at hand, you must first have a model that captures the centralrelevant concepts of the domain.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":36},{"title":"Such patterns are not ready-made solutions, but theyfeed your knowledge crunching process and narrow your search.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":38},{"title":"An opportunity opens up to transform your software into something more expressive and versatile than you expected. This can mean new features or it can just mean the replacement of a big chunk of rigid code with a simple, flexible expression of a deeper model.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":40},{"title":"Nonetheless, it provides a good context for thinking about domain refactoring.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":43},{"title":"They fight entropy, and they are the frontline protection against a fossilized legacy.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":47},{"title":"Slowly but surely, the team assimilates knowledge and crunches it into a model. Deep models can emerge gradually through a sequence of small refactorings, an object at a time: a tweaked association here, a shifted responsibility there.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":51},{"title":"Versatility and explanatory power suddenly increase even as complexity evaporates.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":55},{"title":"evaporate","target":"evaporate","line":56},{"title":"syndicated loans","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":58},{"title":"A major example was the creeping understanding that the shares in a Facility were only aguideline to participation in any particular loan draw-down.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":61},{"title":"Refinements of this kind allowed us to keep up as the rules of various transactions became clearer. But complexity was increasing, and we did not seem to be converging quickly onto really solid functionality.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":63},{"title":"We began to suspect that our difficulties were symptomatic of a basic design problem.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":67},{"title":"symptomatic","target":"symptomatic","line":70},{"title":"Suddenly one week it dawned on us what was wrong.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":73},{"title":"This revelation had wide repercussions.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":77},{"title":"When the drawdown amounts are added to the Loan, the shares of the Loan are no longer proportional to the shares of the Facility.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":83},{"title":"A few tumultuous days later I had sketched a model of shares, drawing on the language used in the discussions with experts and the scenarios we had explored together.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":87},{"title":"It freed the Loan’s Shares to depart from the proportions of the Facility’s Shares while keeping in place the valid constraints on totals, fee distributions, and so on.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":91},{"title":"They had deferred to our software knowledge and assumed it was useful to the technical design.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":93},{"title":"defer to","target":"defer to","line":95},{"title":"A Sobering Decision","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":97},{"title":"You might reasonably assume that we would have been elated at this point.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":101},{"title":"The gospel of refactoring is that you always go in small steps, always keeping everything working.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":103},{"title":"But to refactor our code to this new model would require changing a lot of supporting code, and there would be few, if any, stable stopping points in between.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":105},{"title":"We knew the political situation was unstable, so we’d cope if we had to. And we were tired. But, yes, it was a simpler solution that fit the business much better. In the long run it was a lower risk.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":107},{"title":"The mystifyingly unexpected requirement changes stopped. The rounding logic, though never exactly simple, stabilized and made sense. We delivered version one and the way was clear to version two. My nervous breakdown was narrowly averted.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":109},{"title":"Much as we might like it to be otherwise, progress isn’t a smooth ride. The transition to a really deep model is a profound shift in your thinking and demands a major change to the design.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":111},{"title":"Don’t become paralyzed trying to bring about a breakthrough.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":113},{"title":"Most of the time is spent making piecemeal improvements, with model insights emerging gradually during each successive refinement.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":116},{"title":"To set the stage for a breakthrough, concentrate on knowledge crunching and cultivating a robust ubiquitous LANGUAGE. Probe for important domain concepts and make them explicit in the model (as discussed in Chapter 9). Refine the design to be suppler (see Chapter 10). Distill the model (see Chapter 15).Push on these more predictable levers, which increase clarity—usually a precursor of breakthroughs.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":120},{"title":"cultivate","target":"cultivate","line":122},{"title":"probe","target":"probe","line":123},{"title":"Don’t hold back from modest improvements, which gradually deepen the model, even if confined within the same general conceptual framework. Don’t be paralyzed by looking too far forward. Just be watchful for the opportunity.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":127}],"class_name":"SmartBlock"},"smart_blocks:DDD 的实战 （第八章）.md#": {"path":null,"last_embed":{"hash":null},"embeddings":{"Xenova/jina-embeddings-v2-base-zh":{"vec":null,"last_embed":{"hash":"550f09ef43b0f192e6c0779dc8ea4766f9f365c31833267bcfd2c60cfa2341eb","tokens":5605}}},"text":null,"length":0,"last_read":{"hash":"550f09ef43b0f192e6c0779dc8ea4766f9f365c31833267bcfd2c60cfa2341eb","at":1742533448664},"key":"DDD 的实战 （第八章）.md#","lines":[1,129],"size":15324,"outlinks":[{"title":"Of course, the real challenge is to actually find an incisive model, one that captures subtle concerns of the domain experts and can drive a practical design.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":1},{"title":"Rather than making elaborate up-front design decisions, developers take code through a continuous series of small, discrete design changes, each leaving existing functionality unchanged while making the design more flexible or easier to understand.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":4},{"title":"But nearly all the literature on how to refactor focuses on mechanical changes to the code that make it easier to read or to enhance at a very detailed level.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":8},{"title":"refactoring to a deeper model.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":12},{"title":"but we shouldn’t get sidetracked trying to reduce domain modeling to a cookbook or a toolkit.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":15},{"title":"A deep model provides a lucid expression of the primary concerns of the domain experts and their most relevant knowledge while it sloughs off the superficial aspects of the domain.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":19},{"title":"slough","target":"slough","line":21},{"title":"Versatility, simplicity, and explanatory power come from a model that is truly in tune with the domain.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":24},{"title":"A well-worn glove becomes supple at the points where the fingers bend, while other parts are stiff and protective.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":31},{"title":"In addition to facilitating change, a supple design contributes to the refinement of the model itself.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":34},{"title":"To create a design really fitted to the problem at hand, you must first have a model that captures the centralrelevant concepts of the domain.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":36},{"title":"Such patterns are not ready-made solutions, but theyfeed your knowledge crunching process and narrow your search.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":38},{"title":"An opportunity opens up to transform your software into something more expressive and versatile than you expected. This can mean new features or it can just mean the replacement of a big chunk of rigid code with a simple, flexible expression of a deeper model.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":40},{"title":"Nonetheless, it provides a good context for thinking about domain refactoring.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":43},{"title":"They fight entropy, and they are the frontline protection against a fossilized legacy.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":47},{"title":"Slowly but surely, the team assimilates knowledge and crunches it into a model. Deep models can emerge gradually through a sequence of small refactorings, an object at a time: a tweaked association here, a shifted responsibility there.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":51},{"title":"Versatility and explanatory power suddenly increase even as complexity evaporates.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":55},{"title":"evaporate","target":"evaporate","line":56},{"title":"syndicated loans","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":58},{"title":"A major example was the creeping understanding that the shares in a Facility were only aguideline to participation in any particular loan draw-down.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":61},{"title":"Refinements of this kind allowed us to keep up as the rules of various transactions became clearer. But complexity was increasing, and we did not seem to be converging quickly onto really solid functionality.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":63},{"title":"We began to suspect that our difficulties were symptomatic of a basic design problem.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":67},{"title":"symptomatic","target":"symptomatic","line":70},{"title":"Suddenly one week it dawned on us what was wrong.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":73},{"title":"This revelation had wide repercussions.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":77},{"title":"When the drawdown amounts are added to the Loan, the shares of the Loan are no longer proportional to the shares of the Facility.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":83},{"title":"A few tumultuous days later I had sketched a model of shares, drawing on the language used in the discussions with experts and the scenarios we had explored together.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":87},{"title":"It freed the Loan’s Shares to depart from the proportions of the Facility’s Shares while keeping in place the valid constraints on totals, fee distributions, and so on.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":91},{"title":"They had deferred to our software knowledge and assumed it was useful to the technical design.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":93},{"title":"defer to","target":"defer to","line":95},{"title":"A Sobering Decision","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":97},{"title":"You might reasonably assume that we would have been elated at this point.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":101},{"title":"The gospel of refactoring is that you always go in small steps, always keeping everything working.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":103},{"title":"But to refactor our code to this new model would require changing a lot of supporting code, and there would be few, if any, stable stopping points in between.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":105},{"title":"We knew the political situation was unstable, so we’d cope if we had to. And we were tired. But, yes, it was a simpler solution that fit the business much better. In the long run it was a lower risk.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":107},{"title":"The mystifyingly unexpected requirement changes stopped. The rounding logic, though never exactly simple, stabilized and made sense. We delivered version one and the way was clear to version two. My nervous breakdown was narrowly averted.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":109},{"title":"Much as we might like it to be otherwise, progress isn’t a smooth ride. The transition to a really deep model is a profound shift in your thinking and demands a major change to the design.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":111},{"title":"Don’t become paralyzed trying to bring about a breakthrough.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":113},{"title":"Most of the time is spent making piecemeal improvements, with model insights emerging gradually during each successive refinement.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":116},{"title":"To set the stage for a breakthrough, concentrate on knowledge crunching and cultivating a robust ubiquitous LANGUAGE. Probe for important domain concepts and make them explicit in the model (as discussed in Chapter 9). Refine the design to be suppler (see Chapter 10). Distill the model (see Chapter 15).Push on these more predictable levers, which increase clarity—usually a precursor of breakthroughs.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":120},{"title":"cultivate","target":"cultivate","line":122},{"title":"probe","target":"probe","line":123},{"title":"Don’t hold back from modest improvements, which gradually deepen the model, even if confined within the same general conceptual framework. Don’t be paralyzed by looking too far forward. Just be watchful for the opportunity.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":127}],"class_name":"SmartBlock"},
"smart_blocks:DDD 的实战 （第八章）.md#": {"path":null,"last_embed":{"hash":null},"embeddings":{"Xenova/jina-embeddings-v2-base-zh":{"vec":[0.0374254,-0.02117371,-0.04512089,-0.00798954,-0.02597933,0.0152695,-0.02767305,-0.00598863,0.07998281,0.02973596,0.00326553,0.00225781,-0.05759815,0.04139431,-0.02990927,0.05231927,-0.01965366,-0.04452442,-0.01388095,-0.03690272,-0.01813953,-0.03236845,-0.02596025,0.03184074,0.00386117,0.01857758,-0.0094464,-0.05722836,0.02527859,0.01309761,0.0891004,-0.01955556,-0.03312736,-0.02784082,-0.02476759,-0.0498376,0.09603139,-0.0060493,-0.00835031,0.05639345,-0.0484769,0.03621521,-0.06441813,0.00024472,-0.07886656,0.03149025,0.05293124,-0.01195623,-0.03139308,-0.02704998,-0.02342295,-0.05440444,0.00173794,-0.0145079,0.0190979,0.00905826,-0.00546132,-0.02110582,-0.02793693,0.03278307,0.00758549,-0.03292751,0.06940679,0.01982754,-0.03823258,0.0021615,-0.0158278,-0.03204981,0.00502763,-0.03032137,-0.03196705,-0.02143364,0.00089459,-0.0408589,-0.0048845,-0.03118428,0.01529273,0.00095054,-0.06189725,-0.03675934,-0.01845284,-0.00072869,-0.03982163,-0.02595022,0.01923049,-0.03603452,0.05122638,-0.06858622,-0.08996697,-0.02520411,0.03763264,-0.02434653,-0.01576483,0.02495363,0.0197711,-0.05185514,-0.0052,-0.00398947,-0.00005724,-0.05450812,-0.02074986,-0.04433377,-0.04441603,-0.0681362,-0.03025779,0.03329992,-0.02859865,-0.00035726,0.02536037,0.05948503,0.04846559,-0.00095074,0.0497798,-0.074296,-0.03229651,0.02148215,0.02219741,0.02399892,0.05570365,0.0420414,0.05476599,-0.02791864,0.0085657,0.0183158,-0.0505661,-0.0287758,-0.00513691,-0.0456935,0.06281117,-0.04642591,-0.06044829,0.01201394,-0.01189224,-0.002068,-0.04475553,-0.0237779,0.03687802,-0.02029496,-0.06880838,-0.02800222,0.04352383,-0.0190476,-0.01850251,-0.00305342,0.03153989,0.06053068,-0.01642241,0.00047322,-0.0430808,-0.02082131,-0.04577987,-0.01618201,-0.03949074,-0.02187914,-0.04828752,-0.03593651,0.0058834,0.00684661,-0.04473107,0.0411128,-0.00719359,0.04525667,-0.01967368,0.022811