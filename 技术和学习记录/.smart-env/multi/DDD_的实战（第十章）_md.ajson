63,-0.04183765,-0.00505492,-0.07074323,-0.01944887,0.00212232,0.039429,0.07883794,-0.01656637,-0.02031151,-0.04636886,-0.05667091,-0.01257579,0.00425853,-0.000766,-0.05248625,-0.05385071,-0.00352152,0.00732399,0.03373498,0.00089291,0.0518371,0.02859197,-0.01722996,-0.02144268,0.00688711,-0.07337239,0.00669125,-0.0101926,0.0207966,0.0140022,0.00271621,0.04124257,-0.02108947,-0.02336499,-0.00702405,0.04170426,-0.03010111,-0.03565481,0.00926085,-0.01502705,-0.01422242,-0.00621878,-0.0701676,-0.05278974,0.00017346,0.04183019,0.04670903,-0.0050638,-0.03222113,-0.0280503,0.03946309,-0.01251566,0.05018046,-0.01436706,-0.0030411,0.01866074,0.0616043,-0.08425878,-0.00900866,-0.00375609,0.01751713,0.10111265,0.0236406,0.01817833,-0.07650153,0.03512159,0.00290283,-0.00812793,-0.02828418,-0.03918761,0.00000127,-0.03458134,0.01027514,-0.02726351,-0.01325325,0.01391339,-0.0202248,-0.00434478,-0.04823115,0.03079755],"last_embed":{"hash":"538836c32d3f7b52cadd7df8b696949c9dcf1f04b134a9ce1ef22b82b42f133c","tokens":371}}},"text":null,"length":0,"last_read":{"hash":"538836c32d3f7b52cadd7df8b696949c9dcf1f04b134a9ce1ef22b82b42f133c","at":1742533811175},"key":"DDD 的实战（第十章）.md#Domain-Specific Languages","lines":[187,194],"size":1037,"outlinks":[{"title":"In this style, client code is written in a programming language tailored to a particular model of a particular domain.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":3},{"title":"I’m all in favor of learning advanced technology and design concepts, but we have to soberly assess the skills of a particular team, as well as the likely skills of future maintenance teams. Also, there is value in the seamlessness of an application and a model implemented in the same language.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":6}],"class_name":"SmartBlock"},
