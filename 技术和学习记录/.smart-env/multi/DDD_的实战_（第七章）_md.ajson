1054642,-0.02126233,-0.04309866,0.00531675,-0.02360531,0.03996191,-0.00918905,0.05394745,0.00421411,-0.02352951,0.02230678,0.02247547,-0.02316425,0.00585562,-0.00232094,-0.02111141,0.04713395,0.00874652,-0.00095843,0.01381597,0.00711559,-0.01449627,0.03996278,0.02533505,-0.03151406,0.01356567,0.01008488,-0.02640626,0.00709068,0.00736286,0.08002,-0.03891252,-0.06076239,-0.00649625,-0.04492583,-0.03922417,0.03374428,-0.01101445,-0.01180506,-0.01921832,0.0456547,0.06438085,0.01938735,0.02888982,-0.01188714,-0.01493354,-0.03507403,-0.00759261,-0.00382989,-0.01362634,0.03017858,0.01335526,-0.01565227,-0.02139388,0.03458242,-0.05544603,-0.02515167,0.06060875,0.00422733,0.03367247,-0.0113556,0.03076311,0.03052332,0.0444211,0.06784014,0.02874035,0.0080835,-0.06778699,0.1105984,0.02304162,0.00049996,-0.02386852,-0.05565945,0.0406308,0.03523029,-0.00460757,-0.00884346,-0.05437952,0.00335044,0.03932692,-0.0474851,-0.04442934,0.01474584,-0.00880555,-0.04444846,0.04807426,0.02928076,0.01000884,-0.07347882,-0.02708104,0.02917443,0.06710619,0.06520598,-0.03069079,-0.01521512,-0.1002984,-0.02677821,0.00002523,-0.09819955,0.03159343,0.02851797,0.01994525,-0.00522621,-0.04264857,-0.00458944,-0.00692002,0.00069197,0.03212114,0.0214068,-0.00086007,0.02085294,-0.04968659,0.06038256,-0.01647922,0.03149983,-0.01955303,-0.01234764,0.0735836,-0.02960323,0.03498495,-0.00308286,-0.04057962,-0.0002923,0.01514004,0.01952168,-0.01170219,0.04335688,0.02368147,-0.0497143,0.02244036,-0.0330359,-0.02330189,-0.02605909,-0.00608667,-0.0345021,-0.02669324,0.00773055,0.08880241,0.02731852,-0.02828138,-0.0507737,-0.09614882,0.02556164,-0.04554424,0.04227255,-0.01597653,0.03079169,-0.01653529,0.02999036,-0.02161962,-0.03673828,-0.03448837,-0.05089852,-0.01471008,0.04234617,0.01264131,0.00249065,0.01473536,-0.04749783,0.02035513,0.06770742,-0.02439536,0.03149283,0.00860021,0.03808531,-0.00618581,0.05801737,0.00244771,0.00695224,-0.04788701,-0.00968691,0.02193025,-0.05693341,-0.02667984,-0.0584233,0.04987228,0.00691138,-0.02923046,-0.0167085,0.04558737,0.02149781,-0.0172531,0.00734613,0.01593939,0.02822075,-0.0092699,-0.00133259,-0.00376431,0.02589487,-0.0119965,0.0497534,0.01982594,0.09730059,0.0464856,0.01966407,0.02442085,0.01003129,-0.01100738,0.01032294,0.06096264,0.00000234,-0.03070439,0.02141949,0.01109863,-0.00191486,-0.00281852,0.00118906,-0.00613637,0.01192421,0.01385184,-0.00875868,0.03539201,0.01710326,0.02286193,0.00491111,0.06297743,-0.09187786,-0.01350724,-0.01363308,0.05450168,-0.04435903,0.00329612,0.01998096,-0.01033732,0.0238902,0.00924961,-0.03350596,0.02513405,0.00540488,-0.04912731,-0.01427724,0.00891562,0.02719365,-0.08077964,0.00451768,0.00096002,0.04148914,-0.03361805,-0.00106103,0.02014472,-0.07859915,0.02576549,-0.04948473,0.06099688,-0.00771456,0.08063818,0.02590325,-0.01892969,0.00904069,0.01024998,0.01932064,-0.02615788,0.02162781,0.03616083,-0.04368555,-0.01645999,-0.01238217,0.05774379,0.04589453,0.02227646,0.02157788,-0.04442436,0.02113136,0.01457509,-0.02497591,-0.00291822,-0.03852127,0.02539892,-0.0580598,-0.0619086,0.02781616,-0.01246482,-0.02217793,-0.00445368,-0.00101252,-0.01889625,0.01938197,0.01169621,-0.00200113,0.07957151,0.04798916,0.01704014,-0.05296652,-0.01515474,0.00746235,-0.02568421,0.01702374,-0.01388695,-0.01333481,0.01167605,-0.04092801,-0.04173534,-0.01739234,0.03753458,0.01958782,0.01161268,0.00416879,0.06190626,0.03560643,-0.03537041,-0.04926616,0.02046741,0.04874656,-0.01357523,-0.02031085,-0.01728029,-0.02255105,-0.01933072,-0.05193106,-0.01705112,-0.02228951,0.009828,-0.06593675,0.02881684,-0.0030908,0.02732985,-0.00407303,0.02519347,0.03319209,0.02099128,-0.03120597,-0.00235438,0.06867707,0.03862785,-0.04337604,0.04052824,-0.0129769,-0.04294218,-0.01062293,0.04364144,-0.04726958,0.01888082,-0.02659097,-0.0229234,-0.01323628,-0.02761008,0.05816586,0.02267809,-0.0461302,0.02230261,0.0184868,0.07770425,-0.03448132,0.1050185,-0.00488081,-0.02469872,-0.05383542,-0.01447183,0.02147132,-0.03206753,-0.00154275,-0.03937642,0.01298627,-0.05886293,0.0035261,0.02638032,0.02437927,0.0834626,-0.01543486,-0.03588398,-0.06008293,-0.0205244,0.00089157,0.01908262,0.00016256,-0.02274426,-0.02782015,-0.02543361,0.01153528,0.00654313,0.00506934,0.0266984,0.01659268,-0.03315057,-0.00624899,-0.0124014,-0.05166574,0.00958288,-0.01243228,0.01158587,0.04839573,0.01951437,0.01368762,-0.02409389,-0.03758616,0.00596901,0.05850719,-0.04915268,-0.05170662,0.03889382,-0.03439475,0.00617035,0.00186765,-0.04989623,-0.06829947,-0.01838565,0.05166972,0.04973669,-0.01011585,-0.00685208,0.00562967,0.0634985,-0.04736605,0.10238624,-0.0177135,0.00801835,0.027045,0.06198708,-0.0590659,-0.00548084,-0.00582174,0.02143895,0.02471473,0.03008898,-0.00518503,-0.1008096,0.03873481,0.0083655,-0.00692264,-0.05595435,-0.05083523,0.00000119,0.00465779,0.00977301,-0.06581114,0.00383342,0.03011627,-0.01595291,-0.00289828,-0.06088541,-0.0080321],"last_embed":{"hash":"e8def17a053d9814f4bed74fb77d7945faf31888b3196856b229ad0d6a9db93d","tokens":6074}}},"text":null,"length":0,"last_read":{"hash":"e8def17a053d9814f4bed74fb77d7945faf31888b3196856b229ad0d6a9db93d","at":1742533805338},"key":"DDD 的实战 （第七章）.md#","lines":[1,125],"size":18007,"outlinks":[{"title":"elaborate","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":1},{"title":"elaborate","target":"elaborate","line":3},{"title":"This class would probably be elaborated into a hierarchy of different kinds of incidents, suchas loading, unloading, or being claimed by the receiver.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":6},{"title":"Cargoes can ride from place to place by being loaded onto Carriers for the duration of one or more Carrier Movements","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":10},{"title":"In order to frame up a solid implementation, this model still needs some clarification and tightening.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":14},{"title":"employing the building block patterns.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":16},{"title":", an entity in the usualsense of the word","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":18},{"title":"This question calls for consultation with a domain expert.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":19},{"title":"It will initially be a manual entry.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":20},{"title":"Two places with the same name are not the same. Latitude and longitude could provide a unique key, but probably not a very practical one, since those measurements are not of interest to most purposes of this system,and they would be fairly complicated.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":24},{"title":"More likely, the Location will be part of a geographical model of some kind that will relate places according to shipping lanes and other domain-specific concerns. So an arbitrary, internal, automatically generated identifier will suffice.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":26},{"title":"suffice","target":"suffice","line":28},{"title":"If the Customer has a direct reference to every Cargo it has shipped, it will become cumbersome for long-term, repeat Customers.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":31},{"title":"cumbersome","target":"cumbersome","line":32},{"title":"If our application were tracking the inventory of ships, traversal from Carrier Movement to Handling Event would be important. But our business needs to track only the Cargo. Making the association traversable only from Handling Event to Carrier Movement captures that understanding of our business. This also reduces the implementation to a simple object reference, because the direction with multiplicity was disallowed.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":35},{"title":"inventory","target":"inventory","line":37},{"title":"Circular references logically exist in many domains and are sometimes necessary in design as well, but they are tricky to maintain. Implementation choices can help by avoiding holding the same information in two places that must be kept synchronized. In this case, we can make a simple but fragile implementation (in Java) in an initial prototype, by giving Delivery History a List object containing Handling Events. But at some point we’ll probably want to drop the collection in favor of a database lookup with Cargo as the key. This discussion will be taken up again when choosing REPOSITORIES. If the query to see the history is relatively infrequent, this should give good performance, simplify maintenance, and reduce the overhead of adding Handling Events. If this query is very frequent, then it is better to go ahead and maintain the direct pointer. These design trade-offs balance simplicity of implementation against performance. The model is the same; it contains the cycle and the bidirectional association.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":41},{"title":"one, to find the Handling Events for a Delivery History as a possible alternative to the collection, would be local within the Cargo AGGREGATE; the other would be used to find all the operations to load and prepare for a particular Carrier Movement.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":44},{"title":"As discussed previously, the Handling Event is uniquely identified by the combination of the ID of its Cargo, the completion time, and the event type.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":47},{"title":"Unfortunately, the story isn’t quite that simple. The cycle of references, from Cargo to Delivery History to History Event and back to Cargo, complicates instance creation. The Delivery History holds a collection of Handling Events relevant to its Cargo, and the new object must be added to this collection as part of the transaction. If this back-pointer were not created, the objects would be inconsistent.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":49},{"title":"Let’s go back to one of them and, with the benefit of hindsight, stack the design deck in our favor.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":53},{"title":"The need to update Delivery History when adding a Handling Event gets the Cargo AGGREGATE involved in the transaction. If some other user was modifying Cargo at the same time, the HandlingEvent transaction could fail or be delayed. Entering a Handling Event is an operational activity that needsto be quick and simple, so an important application requirement is the ability to enter Handling Eventswithout contention. This pushes us to consider a different design.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":55},{"title":"Replacing the Delivery History’s collection of Handling Events with a query would allow Handling Events to be added without raising any integrity issues outside its own AGGREGATE.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":59},{"title":"To take responsibility for the queries, we’ll add a REPOSITORY for Handling Events.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":63},{"title":"This diagram is a variation on the infrastructure-driven packaging problem raised in Chapter 5.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":69},{"title":"The result is that objects that conceptually have little relationship (low cohesion) are crammed together, and associations run willy-nilly between all the MODULES(high coupling).","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":73},{"title":"Partitioning by pattern may seem like an obvious error, but it is not really any less sensible than separating persistent objects from transient ones or any other methodical scheme that is not grounded in the meaning of the objects.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":78},{"title":"The back office takes care of billing, submitting invoices according to the pricing in the customer’s agreement.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":82},{"title":"This intuitive breakdown could be refined, certainly, in successive iterations, or even replaced entirely, but it is now aiding MODEL-DRIVEN DESIGN and contributing to the UBIQUITOUS LANGUAGE.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":84},{"title":"The sales division","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":88},{"title":"One feature supports yield management by allowing the firm to allocate how much cargo of specific types they will attempt to book based on the type of goods, the origin and destination, or any other factor they may choose that can be entered as a category name.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":91},{"title":"If the Booking Application interacts with it directly, our application will have to accommodate theother system’s design, which will make it harder to keep a clear MODEL-DRIVEN DESIGN and will confusethe UBIQUITOUS LANGUAGE.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":94},{"title":"It will not be a general translation mechanism. It will expose just the features our application needs, and it will reabstract them in terms of our domain model.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":96},{"title":"But we would be missing an opportunity to use language to recast the problem along lines more useful to us.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":101},{"title":"The book Analysis Patterns (Fowler 1996) describes a pattern that addresses this kind of problem: theENTERPRISE SEGMENT.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":103},{"title":"The Allocation Checker will translate between Enterprise Segments and the category names of the external system.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":105},{"title":"It isn’t clear how the Booking Application derives the Enterprise Segment.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":107},{"title":"The only serious constraint imposed by this integration will be that the Sales Management System mustn’t use dimensions that the Allocation Checker can’t turn into Enterprise Segments. (Without applying the ENTERPRISE SEGMENT pattern, the same constraint would force the sales system to use only dimensions that can be used in a query to the Cargo Repository. This approach is feasible, but the sales system spills into other parts of the domain. In this design, the Cargo Repository need only be designed to handle Enterprise Segment, and changes in the sales system ripple only as far as the Allocation Checker, which was conceived as a FACADE in the first place.)","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":110},{"title":"There is no alternative to the second message, which invokes the Sales Management System to answer the basic question of whether a certain cargo should be accepted. But the first message, which derives the Enterprise Segment for a cargo, is based on relatively static data and behavior compared to the allocation decisions themselves.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":117},{"title":"So the Cargo would have to know about the Allocation Checker, which is well outside its conceptual responsibility, and it would be laden with methods for deriving specific types of Enterprise Segment.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":121},{"title":"Therefore, the responsibility for deriving this value lies properly with the object that knows the rules for segmentation, rather than the object that has the data to which those rules apply.","target":"obsidian://booknote?type=annotation&book=resources/Domain-Driven%20Design%20Tackling%20Complexity%20in%20the%20Heart%20of%20Software%20by%20Eric%20Evans%20(z-lib.org","line":123}],"class_name":"SmartBlock"},
