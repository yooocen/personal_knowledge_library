views:
  - type: table
    name: obsidian相关
    filters:
      and:
        - file.tags.contains("obsidian")
    order:
      - file.name
      - tags
  - type: table
    name: lazyvim
    filters:
      and:
        - file.tags.containsAny("vim", "neovim")
  - type: table
    name: lazygit
    filters:
      and:
        - file.basename.contains("lazygit")
  - type: table
    name: tmux
    filters:
      and:
        - file.basename.contains("tmux")
